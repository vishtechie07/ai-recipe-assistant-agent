# Copy to .env and fill in your values (.env is gitignored)
OPENAI_API_KEY=sk-your-openai-api-key-here
# Required: unique secret, at least 32 characters (do NOT use the old placeholder below)
APP_ENCRYPTION_KEY=

# Local dev profile (verbose logs). Railway auto-activates prod when RAILWAY_* env is set.
SPRING_PROFILES_ACTIVE=dev

# Optional# OPENAI_MODEL_RECIPE=gpt-4o-mini
# OPENAI_MODEL_TIPS=gpt-4o-mini
# APP_DEFAULT_KEY_MAX_RECIPES=5
